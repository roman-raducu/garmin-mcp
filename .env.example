PYTHONUNBUFFERED=1
GARMIN_STATE_DB_PATH=/var/lib/garmin-mcp/garmin_state.db
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT_SECONDS=120

# Optional direct token bootstrap. Prefer this over repeated live logins.
# GARMIN_EMAIL=
# GARMIN_OAUTH1_TOKEN=
# GARMIN_OAUTH2_TOKEN=
